`timescale 1ns/1ps

module tb_alu();

    // 1. Signal declarations
    reg [7:0] a, b;
    reg [2:0] opcode;
    wire [7:0] result;
    wire zero, carry;

    // 2. DUT instantiation
    alu uut (
        .a(a),
        .b(b),
        .opcode(opcode),
        .result(result),
        .zero(zero),
        .carry(carry)
    );

    // 3. Clock generation (if needed, not present in the alu module)
    // reg clk = 0;
    // always #5 clk = ~clk;  // 10ns period

    // 4. Waveform dump
    initial begin
        $dumpfile("dump.vcd");
        $dumpvars(0, tb_alu);
    end

    // 5. Test stimulus with comprehensive coverage
    integer test_count = 0;
    initial begin
        test_count = 0;
        // Basic functionality: All input combinations
        while (test_count < 50) begin
            a = $random;
            b = $random;
            opcode = $random;

            // Edge cases: All 0s, all 1s, alternating patterns
            if ((a == 8'h00) && (b == 8'h00)) begin
                opcode = 3'b000; // Plus
            end else if ((a == 8'hFF) && (b == 8'hFF)) begin
                opcode = 3'b000; // Plus
            end else if ((a[0] == 1'b1 && a[1] == 1'b0) &&
                         (b[0] == 1'b0 && b[1] == 1'b1)) begin
                opcode = 3'b000; // Plus
            end

            // Boundary values: Min/max values
            if ((a == 8'h00) && (b == 8'h00)) begin
                opcode = 3'b001; // Minus
            end else if ((a == 8'h7F) && (b == 8'h7F)) begin
                opcode = 3'b001; // Minus
            end else if ((a[0] == 1'b1 && a[1] == 1'b0) &&
                         (b[0] == 1'b0 && b[1] == 1'b1)) begin
                opcode = 3'b001; // Minus
            end

            // Endpoint cases
            if ((a == 8'h00) && (b == 8'hFF)) begin
                opcode = 3'b010; // And
            end else if ((a == 8'h7F) && (b == 8'h7F)) begin
                opcode = 3'b010; // And
            end

            // Test all operations
            case (opcode)
                3'b000: check_output(a + b);
                3'b001: check_output(a - b);
                3'b010: check_output(a & b);
                3'b011: check_output(a | b);
                3'b100: check_output(a ^ b);
                3'b101: check_output(~a);
                3'b110: check_output(a << 1);
                3'b111: check_output(a >> 1);
            endcase

            test_count = test_count + 1;
            #10; // Std delay
        end
        $finish;
    end

    // 6. Self-checking with expected values (see task check_output)
    task check_output;
        input expected_value;
        reg [7:0] actual_output;
        begin
            actual_output = result;
            if (actual_output !== expected_value) begin
                $display("ERROR at time %0t: Expected %h, Got %h", 
                         $time, expected_value, actual_output);
                error_count = error_count + 1;
            end
        end
    endtask

    integer error_count = 0;

endmodule